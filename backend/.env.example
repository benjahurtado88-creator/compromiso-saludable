# Credenciales de la app de Strava (para conectar datos reales).
# 1) Registrá una app GRATIS en https://www.strava.com/settings/api
# 2) Copiá este archivo a backend/.env y completá los valores.
# 3) NUNCA subas el .env real a git (está en .gitignore).

STRAVA_CLIENT_ID=tu_client_id_aqui
STRAVA_CLIENT_SECRET=tu_client_secret_aqui

# Se completan solos al conectar (no los toques a mano):
# STRAVA_REFRESH_TOKEN=
